{
  "name": "git-encrypt",
  "version": "0.1.0",
  "description": "Transparent Git encryption using age-encryption and git hooks",
  "type": "module",
  "bin": {
    "git-encrypt": "./dist/git-encrypt"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "age-encryption": "^0.1.0",
    "commander": "^12.0.0",
    "minimatch": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/tmp": "^0.2.6",
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.24.0",
    "simple-git": "^3.0.0",
    "tmp": "^0.2.3",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/"
  ]
}